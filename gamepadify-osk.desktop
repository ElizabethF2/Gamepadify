#!/usr/bin/env xdg-open
[Desktop Entry]
Name=Gamepadify-OSK
GenericName=On-Screen Keyboard
Comment=Gamepadify's On-Screen Keyboard

Icon=input-keyboard
Type=Application
Categories=Utility;
Keywords=keyboard;osk;on-screen keyboard;gamepadify;

Exec=sudo /usr/bin/python3 -Im gamepadify.osk --force-wayland
StartupNotify=false
